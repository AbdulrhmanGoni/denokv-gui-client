{
  "name": "denokv-gui-client",
  "description": "An open source GUI client to browse the data inside a Deno KV database and perform CRUD operations",
  "version": "1.27.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/AbdulrhmanGoni/denokv-gui-client",
  "license": "MIT",
  "author": {
    "email": "abdulrhmangoni@gmail.com",
    "name": "Abdulrhman Goni",
    "url": "https://github.com/AbdulrhmanGoni"
  },
  "main": "packages/entry-point.mjs",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.1.0"
  },
  "scripts": {
    "build": "pnpm run --filter=* build",
    "compile": "pnpm run build && electron-builder build --config electron-builder.mjs",
    "compile:ci": "electron-builder build --config electron-builder.mjs --publish never",
    "test": "playwright test -x ./tests/e2e.spec.ts",
    "start": "node packages/dev-mode.js",
    "release": "commit-and-tag-version",
    "release-bridge-server": "cd ./packages/bridge-server && commit-and-tag-version --path ./",
    "typecheck": "pnpm run --filter=* typecheck",
    "migration": "dbmate -u sqlite:database.dev.sqlite -d packages/main/src/db/migrations -s packages/main/src/db/schema.sql",
    "format:fix": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "checks": "pnpm run build && pnpm run typecheck && pnpm run lint:check && pnpm run format:check",
    "screenshots": "node scripts/takeScreenshots.ts"
  },
  "devDependencies": {
    "@ossign/ossign": "^1.0.11",
    "@playwright/test": "^1.55.0",
    "@types/node": "24.0.3",
    "commit-and-tag-version": "12.7.3",
    "electron": "42.4.1",
    "electron-builder": "26.15.7",
    "oxfmt": "0.57.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.55.0",
    "sharp": "0.35.1"
  },
  "dependencies": {
    "@app/main": "workspace:*",
    "dbmate": "2.33.0"
  },
  "overrides": {
    "lodash": "~4.18.1"
  }
}
