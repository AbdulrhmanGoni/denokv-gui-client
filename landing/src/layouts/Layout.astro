---
const description = "Modern desktop app to browse and manage Deno KV databases";
const title = "Deno KV GUI Client";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL(
        `${import.meta.env.BASE_URL}apple-touch-icon-180x180.png`,
        Astro.site,
      )}
    />
    <meta property="og:image:width" content="180" />
    <meta property="og:image:height" content="180" />
    <meta property="og:url" content={canonicalURL} />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="icon"
      type="image/png"
      href={`${import.meta.env.BASE_URL}favicon.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${import.meta.env.BASE_URL}apple-touch-icon-180x180.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href={`${import.meta.env.BASE_URL}apple-touch-icon-ipad-retina-152x152.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href={`${import.meta.env.BASE_URL}apple-touch-icon-iphone-retina-120x120.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="76x76"
      href={`${import.meta.env.BASE_URL}apple-touch-icon-ipad-76x76.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="60x60"
      href={`${import.meta.env.BASE_URL}apple-touch-icon-iphone-60x60.png`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>
      {title} | Desktop app to browse & manage Deno KV Databases
    </title>
    <meta name="description" content={description} />
    <script is:inline>
      const mode =
        localStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");

      document.documentElement.classList.toggle("dark", mode == "dark");
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
