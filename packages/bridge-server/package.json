{
  "name": "@app/bridge-server",
  "version": "9.0.1",
  "description": "A tiny HTTP server to expose Deno KV database over HTTP",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run tests/e2e/index.test.ts tests/units/*",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./kv-utils": {
      "types": "./dist/src/kv-utils.d.ts",
      "import": "./dist/kv-utils.mjs",
      "default": "./dist/kv-utils.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/deno": "^2.5.0",
    "@types/serialize-javascript": "^5.0.4",
    "jsr": "0.14.3",
    "typescript": "6.0.3",
    "unplugin-dts": "1.0.2",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@deno/kv": "0.14.0",
    "@hono/node-server": "2.0.4",
    "hono": "4.12.25",
    "serialize-javascript": "7.0.5"
  },
  "publish": {
    "include": [
      "src",
      "README.md"
    ]
  }
}
